<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE packagegui SYSTEM "../schema/packages.dtd">
<?xml-stylesheet type="text/xsl" href="../xsl/package.xsl"?>
<packagegui>
	<name>adguardhome</name>
	<version>%%PKGVERSION%%</version>
	<title>Services: AdGuard Home</title>
	<addedit_string>AdGuard Home: changed settings</addedit_string>
	<include_file>/usr/local/pkg/adguardhome.inc</include_file>
	<configpath>installedpackages->adguardhome->config</configpath>
	<aftersaveredirect>/pkg_edit.php?xml=adguardhome.xml</aftersaveredirect>
	<service>
		<name>adguardhome</name>
		<rcfile>adguardhome</rcfile>
		<executable>AdGuardHome</executable>
		<description>AdGuard Home</description>
	</service>
	<menu>
		<name>AdGuard Home</name>
		<section>Services</section>
		<configfile>adguardhome.xml</configfile>
		<url>/pkg_edit.php?xml=adguardhome.xml</url>
	</menu>
	<menu>
		<name>AdGuard Home</name>
		<section>Status</section>
		<configfile>adguardhome.xml</configfile>
		<url>/status_adguardhome.php</url>
	</menu>
	<tabs>
		<tab>
			<text>Settings</text>
			<url>/pkg_edit.php?xml=adguardhome.xml</url>
			<active/>
		</tab>
		<tab>
			<text>Status</text>
			<url>/status_adguardhome.php</url>
		</tab>
	</tabs>
	<fields>
		<field>
			<name>Service</name>
			<type>listtopic</type>
		</field>
		<field>
			<fielddescr>Enable</fielddescr>
			<fieldname>enable</fieldname>
			<description>Start AdGuard Home at boot and keep the service running.</description>
			<type>checkbox</type>
		</field>
	</fields>
	<custom_php_install_command>adguardhome_install();</custom_php_install_command>
	<custom_php_deinstall_command>adguardhome_deinstall();</custom_php_deinstall_command>
	<custom_php_resync_config_command>adguardhome_sync();</custom_php_resync_config_command>
</packagegui>
